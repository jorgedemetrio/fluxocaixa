{
  "name": "fluxo-caixa-e2e",
  "version": "1.0.0",
  "description": "Testes E2E com Playwright para o sistema Fluxo de Caixa",
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
